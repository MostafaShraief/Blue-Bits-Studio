# =======================================
# Blue Bits - Git Ignore
# =======================================

# -------------------- Python --------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/
.mypy_cache/
*.egg-info/
dist/
build/
.ruff_cache/

# Virtual Environment
.venv/
venv/
env/

# -------------------- Node.js --------------------
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# -------------------- Environment --------------------
.env
.env.local
.env.*.local
*.key
*.pem
secrets/

# -------------------- IDE --------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -------------------- OS --------------------
.DS_Store
Thumbs.db
desktop.ini

# -------------------- Logs --------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -------------------- Generated Images --------------------
*.svg
*.png
!docs/outputs/*.png
!docs/outputs/*.svg

# -------------------- Test Outputs --------------------
# (These are regenerated by AI - not needed in git)
test-output/
coverage/
.nyc_output/
htmlcov/

# -------------------- Temp Files --------------------
tmp/
temp/
*.tmp
*.bak

# -------------------- OpenCode --------------------
.opencode/

# -------------------- Binary --------------------
*.exe
*.dll
*.so
*.dylib